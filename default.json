{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:best-practices",
        "github>aquaproj/aqua-renovate-config#2.12.1",
        "github>aquaproj/aqua-renovate-config:aqua-renovate-config#2.12.1(default\\.json)",
        ":timezone(Asia/Tokyo)",
        "schedule:daily"
    ],
    "prHourlyLimit": 0,
    "prConcurrentLimit": 0,
    "packageRules": [
        {
            "matchDepNames": [
                "aquaproj/aqua-registry"
            ],
            "extends": [
                "schedule:monthly"
            ]
        }
    ]
}
